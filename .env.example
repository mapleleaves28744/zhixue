# App
APP_NAME=zhixue-workshop
APP_ENV=development
DEBUG=true

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL / pgvector
POSTGRES_USER=zhixue
POSTGRES_PASSWORD=zhixue_password
POSTGRES_DB=zhixue
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://zhixue:zhixue_password@postgres:5432/zhixue

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change_me_in_local_env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Provider
LLM_PROVIDER=mock
LLM_MODEL_NAME=mock-learning-model
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60

# Embedding Provider
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=mock-embedding
EMBEDDING_DIMENSION=1536

# File Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./storage
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,ppt,pptx,txt,md

# Wiki
WIKI_DEFAULT_COURSE_NAME=数据结构
WIKI_REQUIRE_SOURCE=true
WIKI_ENABLE_VERSIONING=true

# Evolution
EVOLUTION_ENABLE_AUTO_APPLY_LOW_RISK=true
EVOLUTION_REQUIRE_CONFIRM_MEDIUM_RISK=true
EVOLUTION_REQUIRE_ADMIN_HIGH_RISK=true
EVOLUTION_DEFAULT_RISK_LEVEL=low
